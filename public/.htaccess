# Apache config pre statický SPA build (Websupport)

# Vynúť HTTPS
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Redirect HTTP -> HTTPS
  RewriteCond %{HTTPS} off
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

  # NEPREPISUJ /api/* (to obsluhuje backend, nie SPA)
  RewriteCond %{REQUEST_URI} !^/api(/|$)

  # SPA fallback: ak požadovaný súbor/adresár neexistuje, vráť index.html
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteRule ^ index.html [L]
</IfModule>

# Kompresia
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json application/xml image/svg+xml
</IfModule>

# Cache hlavičky
<IfModule mod_expires.c>
  ExpiresActive On

  # Hashované assety (JS/CSS/obrázky) – dlhý cache
  ExpiresByType application/javascript "access plus 1 year"
  ExpiresByType text/css "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"

  # HTML – nikdy necachovať (aby sa načítala nová verzia appky)
  ExpiresByType text/html "access plus 0 seconds"
</IfModule>

<IfModule mod_headers.c>
  <FilesMatch "\.html$">
    Header set Cache-Control "no-cache, no-store, must-revalidate"
  </FilesMatch>

  <FilesMatch "\.(js|css|png|jpg|jpeg|svg|webp|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
</IfModule>

# Bezpečnostné hlavičky
<IfModule mod_headers.c>
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Vlastná 404 -> SPA
ErrorDocument 404 /index.html
